rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /resumes/{fileName} {
      allow read: if request.auth != null
        && request.auth.token.email.matches('.*@gridxenergy[.]in$');

      // Public create (careers page): no auth so uploads work without Anonymous sign-in.
      allow create: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|application/msword|application/vnd\\.openxmlformats-officedocument\\.wordprocessingml\\.document');

      allow update: if false;

      allow delete: if request.auth != null
        && request.auth.token.email.matches('.*@gridxenergy[.]in$');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
