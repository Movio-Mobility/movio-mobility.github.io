rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Anyone can upload a resume (max 10 MB, PDF/Word only)
    match /resumes/{fileName} {
      allow read: if request.auth != null
        && request.auth.token.email.matches('.*@gridxenergy[.]in$');
      allow create: if request.resource.size < 10 * 1024 * 1024;
    }
  }
}
